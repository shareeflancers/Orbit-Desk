        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@inertiajs/react": "^2.3.15",
        "@mantine/colors-generator": "^8.3.15",
        "@mantine/core": "^8.3.15",
        "@mantine/hooks": "^8.3.15",
        "@mantine/notifications": "^8.3.15",
        "@vitejs/plugin-react": "^5.1.4",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    }
